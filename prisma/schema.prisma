generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HeroImage {
  id Int @id @default(autoincrement())

  imageUrl  String
  altText   String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id Int @id @default(autoincrement())

  purpose    String
  fullName   String
  email      String
  phone      String?
  city       String?
  company    String?
  guards     String?
  message    String

  cvFileName String?
  cvFileType String?
  cvFileUrl  String?

  createdAt DateTime @default(now())
}
